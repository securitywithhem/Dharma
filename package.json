{
  "name": "dharma",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted compliance management platform for Indian MSMEs.",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema packages/db/schema.prisma && next build",
    "start": "next start",
    "postinstall": "prisma generate --schema packages/db/schema.prisma",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate --schema packages/db/schema.prisma",
    "db:push": "prisma db push --schema packages/db/schema.prisma",
    "db:migrate": "prisma migrate dev --schema packages/db/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema packages/db/schema.prisma",
    "db:seed": "tsx packages/db/seed.ts",
    "seed:frameworks": "tsx scripts/seed-frameworks.ts",
    "seed:all": "npm run db:seed && npm run seed:frameworks",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f nextjs",
    "docker:reset": "docker compose down -v && docker compose up -d --build"
  },
  "prisma": {
    "seed": "tsx packages/db/seed.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.16.2",
    "@tanstack/react-query": "^5.51.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@types/pdf-parse": "^1.1.5",
    "bullmq": "^5.79.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.408.0",
    "minio": "^8.0.7",
    "next": "^14.2.4",
    "next-auth": "^4.24.7",
    "next-themes": "^0.3.0",
    "nodemailer": "^7.0.7",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.1",
    "tailwind-merge": "^2.4.0",
    "tesseract.js": "^7.0.0",
    "tiptap-markdown": "^0.9.0",
    "uuid": "^14.0.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.1",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.11",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-dropzone": "^4.2.2",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.4",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.39",
    "prisma": "^5.16.2",
    "tailwindcss": "^3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
