# ============================================================
# Dharma – Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env files with real secrets to version control.
# ============================================================

# ────────────────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────
# PostgreSQL
# ────────────────────────────────────────────────────────────
POSTGRES_DB=dharma_db
POSTGRES_USER=dharma
# IMPORTANT: Change this before deploying to staging/production
POSTGRES_PASSWORD=dharmapass
POSTGRES_PORT=5432

# Full connection string (used by Prisma)
DATABASE_URL=postgresql://dharma:dharmapass@localhost:5432/dharma_db?schema=public
DATABASE_POOL_SIZE=20
DATABASE_TIMEOUT=30000

# ────────────────────────────────────────────────────────────
# Redis & BullMQ
# ────────────────────────────────────────────────────────────
# IMPORTANT: Change this before deploying to staging/production
REDIS_PASSWORD=redispass
REDIS_PORT=6379
REDIS_URL=redis://:redispass@localhost:6379

# ────────────────────────────────────────────────────────────
# MinIO (S3-compatible object storage)
# ────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
# IMPORTANT: Change this before deploying to staging/production
MINIO_SECRET_KEY=minioadmin_change_me
MINIO_BUCKET=dharma-evidence
MINIO_REGION=us-east-1
MINIO_CONSOLE_URL=http://localhost:9001

# ────────────────────────────────────────────────────────────
# Ollama (Local LLM runtime)
# ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PORT=11434
OLLAMA_MODEL_LLM=llama3:8b
OLLAMA_MODEL_EMBEDDING=nomic-embed-text

# ────────────────────────────────────────────────────────────
# NextAuth.js Authentication
# ────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
# IMPORTANT: Must be at least 32 characters and kept secret
NEXTAUTH_SECRET=replace-with-a-random-32-character-secret

# Google OAuth (optional – leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Magic link email (optional – leave blank to disable)
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=noreply@dharma.local

# ────────────────────────────────────────────────────────────
# Caddy Reverse Proxy
# ────────────────────────────────────────────────────────────
CADDY_DOMAIN=localhost

# ────────────────────────────────────────────────────────────
# Database Seeding
# ────────────────────────────────────────────────────────────
# Set to "true" to run prisma db seed on container startup
SEED_DATABASE=false

# ────────────────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ────────────────────────────────────────────────────────────
# Port overrides (for Docker Compose)
# ────────────────────────────────────────────────────────────
NEXTJS_PORT=3000

# ──────────────────────────────────────────────────────────────────
# Monitoring (Grafana / Prometheus)
# ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=dharma-grafana
GRAFANA_PORT=3001

# ──────────────────────────────────────────────────────────────────
# Backup configuration
# ──────────────────────────────────────────────────────────────────
# Host path for backup volume (absolute path on the Docker host)
BACKUP_HOST_PATH=/tmp/dharma-backups
BACKUP_RETENTION_DAYS=7

# PDF Signing Key
PDF_SIGNING_KEY=your-secure-32-character-key-here

